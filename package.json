{
  "name": "mcp-app-studio-starter",
  "version": "0.3.0",
  "private": true,
  "description": "Workbench and starter template(s) for MCP App Studio",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/assistant-ui/mcp-app-studio-starter.git"
  },
  "homepage": "https://www.assistant-ui.com/",
  "overrides": {
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "scripts": {
    "dev": "tsx scripts/dev.ts",
    "dev:next": "next dev -p 3002",
    "build": "pnpm run build:demo-bundles && next build",
    "build:demo-bundles": "tsx scripts/build-demo-bundles.ts",
    "start": "next start",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "export": "tsx scripts/export.ts",
    "postinstall": "tsx scripts/postinstall.ts",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  },
  "lint-staged": {
    "*": "biome check --write --no-errors-on-unmatched"
  },
  "dependencies": {
    "@ai-sdk/mcp": "^1.0.21",
    "@ai-sdk/openai": "^3.0.33",
    "@assistant-ui/react": "^0.12.11",
    "@assistant-ui/react-ai-sdk": "^1.3.8",
    "@assistant-ui/react-markdown": "^0.12.4",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lint": "^6.9.4",
    "@codemirror/view": "^6.39.15",
    "@modelcontextprotocol/ext-apps": "^1.1.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@uiw/codemirror-theme-github": "^4.25.5",
    "@uiw/react-codemirror": "^4.25.5",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.2",
    "ai": "^6.0.98",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "geist": "^1.7.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.575.0",
    "mcp-app-studio": "^0.7.1",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-leaflet": "^5.0.0",
    "react-resizable-panels": "^3.0.6",
    "remark-gfm": "^4.0.1",
    "shiki": "^3.22.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "esbuild": "^0.27.3",
    "lint-staged": "^16.2.7",
    "playwright": "^1.58.2",
    "postcss": "^8",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vite": "^7.3.1"
  }
}
